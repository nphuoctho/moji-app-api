{
  "name": "moji-api-app",
  "version": "1.0.0",
  "description": "A simple RESTful API built with Node.js, Express, and TypeScript, featuring MongoDB for data storage, Pino for logging, and Vitest for testing.",
  "main": "./src/server.ts",
  "scripts": {
    "build": "rimraf dist && swc src -d dist --copy-files && tsc --emitDeclarationOnly --project tsconfig.build.json && tsc-alias",
    "dev": "nodemon --watch src --exec tsx src/server.ts",
    "format": "biome format --write src",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "start": "node -r tsconfig-paths/register dist/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "mongoose",
    "pino",
    "vitest",
    "zod",
    "dotenv"
  ],
  "author": "phuoctho.dev",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.21",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "compression": "^1.8.1",
    "helmet": "^8.1.0",
    "i": "^0.3.7",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
