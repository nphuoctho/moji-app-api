{
  "name": "moji-api-app",
  "version": "1.0.0",
  "description": "A simple RESTful API built with Node.js, Express, and TypeScript, featuring MongoDB for data storage, Pino for logging, and Vitest for testing.",
  "main": "main.js",
  "scripts": {
    "build": "tsup",
    "dev": "nodemon --watch src --exec tsx src/main.ts",
    "start": "node dist/main.js",
    "format": "biome format --write src",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "mongoose",
    "pino",
    "vitest",
    "zod",
    "dotenv"
  ],
  "author": "phuoctho.dev",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "compression": "^1.8.1",
    "helmet": "^8.1.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
